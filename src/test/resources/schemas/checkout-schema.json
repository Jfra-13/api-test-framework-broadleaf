{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Checkout Response Schema - Broadleaf Commerce",
  "description": "Validación del contrato de respuesta final del checkout",
  "type": "object",
  "required": ["id", "status", "submitDate", "orderNumber", "total"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "ID único de la orden"
    },
    "orderNumber": {
      "type": "string",
      "description": "Número de orden único del sistema"
    },
    "status": {
      "type": "string",
      "enum": ["SUBMITTED"],
      "description": "Estado MUST ser SUBMITTED para checkout exitoso"
    },
    "submitDate": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha/hora de confirmación de la orden"
    },
    "emailAddress": {
      "type": ["string", "null"],
      "description": "Email del cliente (puede estar vacío para anonymous)"
    },
    "subTotal": {
      "$ref": "#/definitions/Money"
    },
    "total": {
      "$ref": "#/definitions/Money"
    },
    "totalTax": {
      "$ref": "#/definitions/Money"
    },
    "totalShipping": {
      "$ref": "#/definitions/Money"
    },
    "itemCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Debe haber al menos 1 item"
    },
    "customer": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "firstName": { "type": ["string", "null"] },
        "lastName": { "type": ["string", "null"] },
        "emailAddress": { "type": ["string", "null"] }
      }
    },
    "orderItems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "quantity", "skuId"]
      }
    },
    "fulfillmentGroups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "address"]
      }
    },
    "payments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "amount", "transactions"],
        "properties": {
          "transactions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["success", "type", "amount"]
            }
          }
        }
      }
    }
  },
  "definitions": {
    "Money": {
      "type": "object",
      "required": ["amount", "currency"],
      "properties": {
        "amount": { "type": "number" },
        "currency": { "type": "string" }
      }
    }
  }
}

